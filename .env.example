# Firebase - Notificashub (studio-3864746689-59018)
# Copia este archivo a .env.local y completa los valores

# Firebase Client (web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (servidor) - ruta al JSON de clave privada
# Por defecto usa: studio-3864746689-59018-firebase-adminsdk-fbsvc-5cdc673866.json
GOOGLE_APPLICATION_CREDENTIALS=

# Dashboard WhatsApp - contraseña para acceder al panel de mensajes
DASHBOARD_PASSWORD=

# HeartLink - reenvío de mensajes entrantes
HEARTLINK_URL=https://heartlink--heartlink-f4ftq.us-central1.hosted.app
INTERNAL_SECRET=heartlink_internal_2026
